{
  "name": "@chaihuo/course-site",
  "description": "柴火创客 OPC 学院",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "start": "HOST=0.0.0.0 PORT=3001 node dist/server/entry.mjs",
    "preview": "astro preview --port 3001",
    "check": "astro check",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "qr": "bash scripts/gen-qr.sh",
    "prepare": "simple-git-hooks || true"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.1",
    "@iconify-json/lucide": "^1.2.87",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^6.3.8",
    "astro-icon": "^1.1.5",
    "preline": "^4.0.1",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "2.4.16",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.6.3"
  },
  "simple-git-hooks": {
    "pre-commit": "bash scripts/validate-lockfile.sh"
  }
}