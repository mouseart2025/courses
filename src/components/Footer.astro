---
import { Icon } from "astro-icon/components";
const currentYear = new Date().getFullYear();

const locations = [
  {
    city: "深圳",
    tag: "HQ",
    address: "深圳市南山区万科云城设计社区 B622",
    email: "jiayu.wang@seeed.cc",
  },
  {
    city: "成都",
    tag: null,
    address: "成都市青羊区狮马路92号",
    email: "xia.huang@seeed.cc",
  },
];

const footerLinks = {
  about: {
    title: "关于我们",
    links: [
      { label: "学院简介", href: "/about" },
    ],
  },
  social: {
    title: "关注我们",
    links: [
      { label: "抖音", href: "#" },
      { label: "小红书", href: "#" },
      { label: "X", href: "#" },
      { label: "Facebook", href: "#" },
      { label: "Instagram", href: "#" },
    ],
  },
};
---

<footer class="bg-brand-graphite text-white noise-overlay">
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Main Footer Content -->
    <div
      class="py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-y-12 gap-x-8 lg:gap-x-12"
    >
      <!-- Brand Column -->
      <div class="lg:col-span-4">
        <a
          href="/"
          class="inline-flex items-center gap-3 focus-ring rounded-md"
          aria-label="柴火创客学院"
        >
          <img
            src="/logo-horizontal.png"
            alt="柴火创客 CHAIHUO MAKERS"
            class="h-10 w-auto brightness-0 invert"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
          />
          <span class="brand-fallback hidden items-center" aria-hidden="true">
            <span class="text-lg font-bold text-white">柴火创客</span>
          </span>
          <span class="h-7 w-px bg-white/30" aria-hidden="true"></span>
          <span
            class="text-base font-semibold tracking-[0.2em] text-white leading-none"
          >
            学院
          </span>
        </a>
        <p class="mt-4 text-sm text-white/70 leading-relaxed max-w-sm">
          柴火创客学院提供从硬件接入、边缘计算到 AI
          智能体的全链路技术交付能力，让每一个个体都能拥有"一个人也能上场"的全栈交付能力。
        </p>
        <p
          class="mt-6 font-handwriting text-2xl leading-none text-brand-yellow"
          style="font-family: Caveat, 'Noto Sans SC', cursive;"
        >
          since 2011
        </p>
      </div>

      <!-- Location Cards -->
      <div class="md:col-span-2 lg:col-span-5">
        <h4 class="text-base font-bold text-brand-yellow mb-4">联系我们</h4>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {
            locations.map((loc) => (
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <Icon
                    name="lucide:map-pin"
                    class="w-4 h-4 text-brand-yellow shrink-0"
                  />
                  <span class="font-medium text-white">{loc.city}</span>
                  {loc.tag && (
                    <span class="text-[10px] font-mono font-bold bg-brand-yellow text-brand-black px-1.5 py-0.5 rounded">
                      {loc.tag}
                    </span>
                  )}
                </div>
                <p class="text-sm text-white/70 mb-1 pl-6">{loc.address}</p>
                <a
                  href={`mailto:${loc.email}`}
                  class="focus-ring block text-sm text-white/70 pl-6 font-mono hover:text-brand-yellow transition-colors"
                >
                  {loc.email}
                </a>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Links Column -->
      <div class="md:col-span-2 lg:col-span-3 grid grid-cols-2 gap-8">
        <div>
          <h4 class="text-base font-bold text-brand-yellow mb-4">
            {footerLinks.about.title}
          </h4>
          <ul class="space-y-2">
            {
              footerLinks.about.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-white/70 hover:text-brand-yellow transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <h4 class="text-base font-bold text-brand-yellow mb-4">
            {footerLinks.social.title}
          </h4>
          <ul class="space-y-2">
            {
              footerLinks.social.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-white/70 hover:text-brand-yellow transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="py-6 border-t border-white/10">
      <p class="text-sm text-white/50 text-center font-mono">
        &copy; {currentYear} Chaihuo Makerspace Academy. All rights reserved.
      </p>
    </div>
  </div>
</footer>
