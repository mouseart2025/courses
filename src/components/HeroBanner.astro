---
import { Icon } from 'astro-icon/components';

interface CTA {
  label: string;
  href: string;
  variant?: 'primary' | 'secondary';
}

type Panel = 'white' | 'yellow-soft' | 'dark' | 'photo';

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  description?: string;
  ctas?: CTA[];
  panel?: Panel;
  bgImage?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  description,
  ctas = [],
  panel = 'white',
  bgImage,
} = Astro.props as Props;

const hasTitleSlot = Astro.slots.has('title');

const panelBgClass = {
  white: 'bg-white border-b border-neutral-3',
  'yellow-soft': 'bg-brand-yellow-soft border-b border-neutral-3',
  dark: 'bg-brand-graphite',
  photo: 'bg-brand-graphite',
}[panel];

const isDark = panel === 'dark' || panel === 'photo';

const eyebrowColor = isDark ? 'text-brand-yellow' : 'text-brand-red';
const titleColor = isDark ? 'text-white' : 'text-brand-black';
const subtitleColor = isDark ? 'text-white/80' : 'text-neutral-7';
const descriptionColor = isDark ? 'text-white/70' : 'text-neutral-8';

const ctaClass = (variant: CTA['variant']) => {
  if (variant === 'secondary') {
    return isDark
      ? 'border border-white/30 text-white hover:bg-white/10'
      : 'border border-neutral-3 text-brand-black hover:border-brand-black/30 bg-white';
  }
  return isDark
    ? 'bg-brand-red text-white hover:bg-brand-red-hover'
    : 'bg-brand-black text-white hover:bg-black';
};
---

<section
  class:list={['relative overflow-hidden', panelBgClass]}
  style={panel === 'photo' && bgImage
    ? `background-image:url(${bgImage});background-size:cover;background-position:center;`
    : undefined}
>
  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-24">
    <div class="max-w-3xl">
      {
        eyebrow && (
          <p class:list={['text-xs md:text-sm font-mono font-semibold uppercase tracking-widest mb-4', eyebrowColor]}>
            {eyebrow}
          </p>
        )
      }

      <h1
        class:list={[
          'text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.15] tracking-tight',
          titleColor,
        ]}
      >
        {hasTitleSlot ? <slot name="title" /> : title}
      </h1>

      {
        subtitle && (
          <p class:list={['mt-5 text-base md:text-lg font-medium', subtitleColor]}>
            {subtitle}
          </p>
        )
      }

      {
        description && (
          <p
            class:list={[
              'mt-4 text-sm md:text-base leading-relaxed max-w-2xl',
              descriptionColor,
            ]}
          >
            {description}
          </p>
        )
      }

      {
        ctas.length > 0 && (
          <div class="mt-8 flex flex-wrap gap-3">
            {ctas.map((cta) => (
              <a
                href={cta.href}
                class:list={[
                  'focus-ring inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-md text-sm font-semibold transition-colors duration-150',
                  ctaClass(cta.variant),
                ]}
              >
                {cta.label}
                <Icon name="lucide:arrow-right" class="w-4 h-4" />
              </a>
            ))}
          </div>
        )
      }
    </div>
  </div>
</section>
