---
import { Icon } from 'astro-icon/components';
import type { Module } from '../data/modules';

interface Props {
  module: Module;
  variant?: 'compact' | 'full';
}

const { module, variant = 'full' } = Astro.props as Props;

const isM0 = module.id === 'm0';
// M0 = dark flagship card; M1–M5 = calm white hairline cards (yellow stays an accent, not a fill)
const panelClass = isM0 ? 'panel-dark' : 'card-hairline bg-background';

const codeColor = isM0 ? 'text-brand-yellow' : 'text-brand-black';
const titleColor = isM0 ? 'text-brand-yellow' : 'text-brand-black';
const subtitleColor = isM0 ? 'text-white/70' : 'text-neutral-6';
const bodyColor = isM0 ? 'text-white/90' : 'text-neutral-8';
const labelColor = isM0 ? 'text-brand-yellow/80' : 'text-neutral-6';
const listColor = isM0 ? 'text-white/90' : 'text-neutral-8';
const dividerColor = isM0 ? 'border-brand-yellow/20' : 'border-neutral-3';
const footLabelColor = isM0 ? 'text-brand-yellow/80' : 'text-neutral-6';
const footLinkColor = isM0 ? 'text-brand-yellow' : 'text-brand-black';

const illustrationBg = isM0
  ? 'bg-brand-yellow/15 border border-brand-yellow/40' // M0 keeps a soft yellow accent on the dark card
  : 'bg-neutral-1 border border-neutral-3';

const totalDays = Object.values(module.cells).reduce(
  (sum, c) => sum + c.durationDays,
  0,
);
---

<a
  href={`/courses/${module.slug}`}
  class:list={[
    panelClass,
    'panel-interactive focus-ring group relative flex flex-col overflow-hidden',
  ]}
>
  <div class="flex items-start gap-4 p-5 md:p-6">
    <span
      class:list={[
        'text-5xl md:text-6xl font-black font-mono leading-none shrink-0',
        codeColor,
      ]}
    >
      {module.code}
    </span>
    <div class="min-w-0 pt-1.5">
      <h3
        class:list={[
          'text-lg md:text-xl font-bold leading-tight',
          titleColor,
        ]}
      >
        {module.title}
      </h3>
      <p class:list={['text-xs mt-1', subtitleColor]}>{module.subtitle}</p>
    </div>
  </div>

  <div class="px-5 md:px-6">
    <div
      class:list={[
        'aspect-[4/3] w-full rounded-lg flex items-center justify-center overflow-hidden relative',
        illustrationBg,
      ]}
    >
      <img
        src={module.illustration}
        alt={`${module.title} 插画`}
        width="1024"
        height="1024"
        class="w-full h-full object-cover relative z-10"
        loading="lazy"
        onerror="this.style.display='none'; this.nextElementSibling.classList.remove('hidden');"
      />
      <!-- Typographic / Icon Fallback when image fails to load -->
      <div
        class="absolute inset-0 hidden flex flex-col items-center justify-center text-center p-4 z-0 select-none bg-brand-black/5"
      >
        <Icon name="lucide:cpu" class:list={['w-10 h-10 mb-2 opacity-40', isM0 ? 'text-brand-yellow' : 'text-brand-black']} />
        <span class:list={['text-3xl font-mono font-black tracking-wider opacity-30', isM0 ? 'text-brand-yellow' : 'text-brand-black']}>
          {module.code}
        </span>
        <span class:list={['text-[10px] uppercase font-mono mt-1 tracking-widest opacity-40', isM0 ? 'text-white' : 'text-brand-black']}>
          WORKBENCH ACTIVE
        </span>
      </div>
    </div>
  </div>

  <div class="p-5 md:p-6 flex flex-col gap-4 flex-1">
    <p class:list={['text-sm md:text-base leading-relaxed', bodyColor]}>
      {module.oneLiner}
    </p>

    {
      variant === 'full' && (
        <div class="grid grid-cols-2 gap-3 text-xs">
          <div>
            <p
              class:list={[
                'font-semibold mb-1 font-mono uppercase tracking-wider',
                labelColor,
              ]}
            >
              核心硬件
            </p>
            <ul class:list={['space-y-0.5', listColor]}>
              {module.coreHardware.slice(0, 3).map((h) => (
                <li>· {h}</li>
              ))}
            </ul>
          </div>
          <div>
            <p
              class:list={[
                'font-semibold mb-1 font-mono uppercase tracking-wider',
                labelColor,
              ]}
            >
              关键能力
            </p>
            <ul class:list={['space-y-0.5', listColor]}>
              {module.capabilities.slice(0, 3).map((c) => (
                <li>· {c}</li>
              ))}
            </ul>
          </div>
        </div>
      )
    }

    <div
      class:list={[
        'flex items-center justify-between mt-auto pt-3 border-t',
        dividerColor,
      ]}
    >
      <span
        class:list={['text-xs font-mono font-semibold', footLabelColor]}
      >
        约 {totalDays} 天 · L1→L3
      </span>
      <span
        class:list={[
          'inline-flex items-center gap-1 text-sm font-semibold transition-transform duration-200 group-hover:translate-x-1',
          footLinkColor,
        ]}
      >
        查看详情
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </span>
    </div>
  </div>
</a>
