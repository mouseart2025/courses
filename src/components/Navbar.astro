---
import { Icon } from "astro-icon/components";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props as Props;

const navItems = [
  { label: "首页", href: "/" },
  { label: "课程体系", href: "/courses" },
  { label: "选课指南", href: "/paths" },
  { label: "合作咨询", href: "/contact" },
  { label: "关于学院", href: "/about" },
];

function isActive(href: string): boolean {
  if (href === "/") {
    return currentPath === "/";
  }
  return currentPath.startsWith(href);
}
---

<header
  class="sticky top-0 z-50 w-full bg-white border-b-2 border-brand-black"
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a
          href="/"
          class="group inline-flex items-center gap-2.5 focus-ring rounded-md"
          aria-label="柴火创客 OPC 学院首页"
        >
          <img
            src="/favicon.svg"
            alt=""
            width="440"
            height="550"
            class="h-9 md:h-10 w-auto"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='inline-flex'"
          />
          <!-- Fallback when image missing -->
          <span
            class="brand-fallback hidden items-center"
            aria-hidden="true"
          >
            <span class="text-base font-bold text-brand-black">OPC</span>
          </span>

          <span
            class="h-6 w-px bg-gray-300"
            aria-hidden="true"
          ></span>
          <span
            class="text-sm font-semibold tracking-[0.2em] text-brand-black leading-none"
          >
            OPC 学院
          </span>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex md:items-center md:gap-2">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="nav-link focus-ring px-4 py-5 text-sm font-medium"
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </div>

      <!-- Mobile Menu Button -->
      <div class="md:hidden">
        <button
          type="button"
          class="hs-collapse-toggle focus-ring inline-flex justify-center items-center w-10 h-10 rounded-lg border border-gray-200 bg-white text-gray-700 hover:bg-gray-50"
          id="hs-navbar-chaihuo"
          aria-expanded="false"
          aria-controls="hs-navbar-collapse"
          aria-label="打开或关闭导航菜单"
          data-hs-collapse="#hs-navbar-collapse"
        >
          <Icon
            name="lucide:menu"
            class="hs-collapse-open:hidden shrink-0 w-5 h-5"
          />
          <Icon
            name="lucide:x"
            class="hs-collapse-open:block hidden shrink-0 w-5 h-5"
          />
          <span class="sr-only">Toggle navigation</span>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <div
      id="hs-navbar-collapse"
      class="hidden hs-collapse overflow-hidden transition-all duration-300 basis-full grow md:hidden"
      aria-labelledby="hs-navbar-chaihuo"
    >
      <div class="flex flex-col gap-1 py-4">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                "focus-ring px-4 py-3 rounded-lg text-base font-medium transition-colors duration-200",
                isActive(item.href)
                  ? "bg-brand-yellow-light text-brand-yellow-dark"
                  : "text-gray-600 hover:bg-gray-50 hover:text-gray-900",
              ]}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </div>
    </div>
  </nav>
</header>
