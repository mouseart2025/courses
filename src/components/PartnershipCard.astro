---
import { Icon } from 'astro-icon/components';
import type { PartnershipForm } from '../data/partnerships';

interface Props {
  form: PartnershipForm;
}

const { form } = Astro.props as Props;
---

<article
  id={`form-${form.code}`}
  class="card-hairline scroll-mt-24 flex h-full flex-col gap-4 p-5 md:p-6"
>
  <header class="flex items-start justify-between gap-4">
    <div class="flex items-center gap-3">
      <span
        class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-brand-red text-white text-base font-mono font-bold"
      >
        {form.code}
      </span>
      <div>
        <h3 class="text-lg font-bold text-brand-black leading-tight">
          {form.title}
        </h3>
        <p class="text-xs font-mono text-neutral-6 mt-0.5">
          {form.subtitle}
        </p>
      </div>
    </div>
    <Icon name={form.icon} class="w-5 h-5 text-neutral-5 shrink-0" />
  </header>

  <div>
    <p class="text-[11px] font-bold font-mono text-neutral-6 uppercase tracking-wider mb-2">
      合作特性
    </p>
    <ul class="space-y-1.5 text-sm text-neutral-8">
      {
        form.features.map((f) => (
          <li class="flex items-start gap-2">
            <Icon name="lucide:check" class="w-4 h-4 text-brand-red mt-0.5 shrink-0" />
            <span>{f}</span>
          </li>
        ))
      }
    </ul>
  </div>

  <div>
    <p class="text-[11px] font-bold font-mono text-neutral-6 uppercase tracking-wider mb-2">
      交付内容
    </p>
    <div class="flex flex-wrap gap-1.5">
      {
        form.deliverables.map((d) => (
          <span class="inline-block text-xs bg-neutral-1 border border-neutral-3 text-neutral-8 px-2 py-1 rounded-md">
            {d}
          </span>
        ))
      }
    </div>
  </div>

  <a
    href="#partnership-qr"
    class="focus-ring mt-auto inline-flex items-center justify-center gap-2 bg-brand-black text-white font-semibold px-4 py-2.5 rounded-md hover:bg-black transition-colors"
    aria-label={`扫码咨询形态 ${form.code}：${form.title}`}
  >
    扫码咨询此形态
    <Icon name="lucide:qr-code" class="w-4 h-4" />
  </a>
</article>
