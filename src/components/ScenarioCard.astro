---
import { Icon } from 'astro-icon/components';
import type { Scenario } from '../data/partnerships';

interface Props {
  scenario: Scenario;
  compact?: boolean;
}

const { scenario, compact = false } = Astro.props as Props;
---

<article
  id={`scenario-${scenario.id}`}
  class="card-hairline scroll-mt-24 flex h-full flex-col gap-4 p-5 md:p-6"
>
  <header class="flex items-start gap-3">
    <span
      class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-yellow-light text-brand-black"
    >
      <Icon name={scenario.icon} class="w-5 h-5" />
    </span>
    <div class="min-w-0">
      <h3 class="text-base md:text-lg font-bold text-brand-black leading-tight">
        {scenario.title}
      </h3>
      <p class="text-xs font-mono text-neutral-6 mt-0.5">
        {scenario.subtitle}
      </p>
    </div>
  </header>

  <div>
    <p class="text-[11px] font-bold font-mono text-neutral-6 uppercase tracking-wider mb-2">
      服务特性
    </p>
    <ul class="space-y-1.5 text-sm text-neutral-8">
      {
        scenario.features.map((f) => (
          <li class="flex items-start gap-2">
            <Icon name="lucide:dot" class="w-4 h-4 text-brand-red mt-0.5 shrink-0" />
            <span>{f}</span>
          </li>
        ))
      }
    </ul>
  </div>

  {
    !compact && (
      <div>
        <p class="text-[11px] font-bold font-mono text-neutral-6 uppercase tracking-wider mb-2">
          达成效果
        </p>
        <ul class="space-y-1.5 text-sm text-neutral-8">
          {scenario.outcomes.map((o) => (
            <li class="flex items-start gap-2">
              <Icon name="lucide:check" class="w-4 h-4 text-brand-red mt-0.5 shrink-0" />
              <span>{o}</span>
            </li>
          ))}
        </ul>
      </div>
    )
  }

  <footer class="mt-auto pt-3 border-t border-neutral-3">
    <p class="text-[11px] font-mono text-neutral-6 mb-2">适用合作形态</p>
    <div class="flex items-center gap-2">
      {
        scenario.applicableForms.map((code) => (
          <a
            href={`#form-${code}`}
            class="focus-ring inline-flex h-7 w-7 items-center justify-center rounded-full bg-brand-red text-white font-mono font-bold text-xs hover:bg-brand-red-hover transition-colors"
            aria-label={`合作形态 ${code}`}
          >
            {code}
          </a>
        ))
      }
    </div>
  </footer>
</article>
