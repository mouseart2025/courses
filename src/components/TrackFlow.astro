---
import { Icon } from 'astro-icon/components';
import { tracks } from '../data/tracks';
import { getModule } from '../data/modules';
---

<div class="space-y-6">
  <div class="flex items-center gap-3 text-sm text-gray-600">
    <span class="font-semibold text-brand-black">三大课程方向</span>
    <span>按课程目标拼模块；M0 是零基础旗舰入口，M1–M5 按方向组合。</span>
  </div>

  <div class="grid md:grid-cols-2 gap-4">
    {
      tracks.map((track) => (
        <div id={`track-${track.id}`} class="card-hairline bg-background p-5 md:p-6 scroll-mt-24">
          <div class="flex items-start justify-between gap-3 mb-3">
            <div>
              <p class="text-xs font-mono text-brand-red mb-1">{track.tagline}</p>
              <h3 class="text-lg font-bold text-brand-black">{track.name}</h3>
              <p class="text-xs text-gray-600 mt-1">{track.goal}</p>
            </div>
            <Icon
              name="lucide:route"
              class:list={[
                'w-5 h-5 shrink-0',
                track.accent === 'red' ? 'text-brand-red' : 'text-brand-yellow-dark',
              ]}
            />
          </div>
          <p class="text-sm text-gray-600 leading-relaxed mb-4">
            {track.description}
          </p>
          <div class="flex items-center gap-1 flex-wrap">
            {track.moduleIds.map((id, i) => {
              const m = getModule(id)!;
              return (
                <span class="inline-flex items-center gap-1">
                  {i > 0 && (
                    <Icon name="lucide:chevron-right" class="w-4 h-4 text-gray-400 shrink-0" />
                  )}
                  <a
                    href={`/courses/${m.slug}`}
                    class="focus-ring inline-flex"
                  >
                    <span
                      class:list={[
                        'module-tile module-tile--sm',
                        m.accent === 'red' ? 'module-tile--red' : 'module-tile--dark',
                      ]}
                    >
                      {m.code}
                    </span>
                  </a>
                </span>
              );
            })}
          </div>
          <div class="mt-5 border-t border-brand-black/10 pt-4">
            <a
              href={`/paths#track-${track.id}`}
              class="focus-ring inline-flex items-center gap-2 text-sm font-bold text-brand-black hover:text-brand-red transition-colors"
            >
              查看这组课程组合
              <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
          </div>
        </div>
      ))
    }
  </div>

  <div class="text-xs text-gray-500 leading-relaxed">
    · 零基础从「用 AI 造物」开始（M0） · 「造 AI 的物」= M2 · M4 · 「解决方案」= M1 · M3 · M5
  </div>
</div>
