---
import { Icon } from 'astro-icon/components';
import SectionHeader from '../../SectionHeader.astro';
import type { AboutValueItem } from '../../../data/site';

interface Props {
  values: AboutValueItem[];
}

const { values } = Astro.props as Props;
---

<section class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-neutral-1 border-t border-b border-neutral-3">
  <div class="max-w-7xl mx-auto" data-reveal>
    <SectionHeader
      eyebrow="What it means for you"
      title="这为你带来什么价值？"
    />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
      {
        values.map((item) => (
          <div class="card-hairline p-6 md:p-8">
            <span class="inline-flex items-center justify-center w-12 h-12 rounded-lg bg-brand-yellow-light text-brand-black mb-6">
              <Icon name={item.icon} class="w-6 h-6" />
            </span>
            <h3 class="text-lg font-black text-brand-black mb-3">
              {item.title}
            </h3>
            <p class="text-sm text-gray-700 leading-relaxed">
              {item.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
