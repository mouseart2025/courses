---
import { Icon } from 'astro-icon/components';
---

<section
  id="partnership-form"
  class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-brand-graphite text-white relative noise-overlay border-t-2 border-brand-black scroll-mt-20"
>
  <div class="relative z-10 max-w-6xl mx-auto grid md:grid-cols-[1.3fr_1fr] gap-12 items-start">
    <div class="panel-dark p-6 md:p-8 border-2 border-white/20 rounded-2xl shadow-lg relative overflow-hidden bg-brand-graphite">
      <h2 class="text-2xl sm:text-3xl font-black leading-tight text-brand-yellow mb-3">
        填写需求，开启合作
      </h2>
      <p class="text-sm text-white/70 leading-relaxed mb-8">
        留下您的真实合作意向与联系方式，我们将在 3 个工作日内向您反馈量身定制的课程合作建议书。
      </p>

      <div
        id="form-success-box"
        class="hidden mb-6 p-5 bg-brand-yellow text-brand-black border-2 border-brand-black rounded-xl"
        role="status"
        aria-live="polite"
        tabindex="-1"
      >
        <div class="flex items-start gap-3">
          <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-brand-black text-brand-yellow shrink-0">
            <Icon name="lucide:circle-check-big" class="w-5 h-5" />
          </span>
          <div>
            <h4 class="font-black text-lg leading-tight">需求已提交登记！</h4>
            <p class="text-xs text-brand-black/80 mt-1 leading-relaxed">
              感谢您的信任！我们已在本地登记您的意向，将在 3 个工作日内指派顾问专人对接。
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              <a
                id="mailto-prefilled-btn"
                href="mailto:jiayu.wang@seeed.cc?subject=课程合作咨询&body=您好！我想咨询关于柴火创客学院的课程体系合作。"
                class="inline-flex items-center gap-1.5 px-4 py-2 bg-brand-black text-white text-xs font-bold rounded-lg hover:bg-brand-graphite transition-all"
              >
                <Icon name="lucide:send" class="w-3.5 h-3.5" />
                一键发送标准邮件备份
              </a>
            </div>
          </div>
        </div>
      </div>

      <form id="cooperation-web-form" class="space-y-5">
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="form-name" class="block text-xs font-bold font-mono tracking-wider text-brand-yellow mb-1.5">
              NAME / 姓名 *
            </label>
            <input
              type="text"
              id="form-name"
              name="name"
              autocomplete="name"
              required
              placeholder="请输入您的姓名"
              class="maker-input"
            />
          </div>
          <div>
            <label for="form-org" class="block text-xs font-bold font-mono tracking-wider text-brand-yellow mb-1.5">
              ORGANIZATION / 学校或单位名称 *
            </label>
            <input
              type="text"
              id="form-org"
              name="organization"
              autocomplete="organization"
              required
              placeholder="例如：深圳大学工程学院"
              class="maker-input"
            />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="form-role" class="block text-xs font-bold font-mono tracking-wider text-brand-yellow mb-1.5">
              YOUR ROLE / 您的角色 *
            </label>
            <select id="form-role" name="role" required class="maker-input cursor-pointer">
              <option value="" disabled selected>请选择您的角色</option>
              <option value="teacher">高校教师 / 教学主管</option>
              <option value="integrator">智能家居集成商 / IT 运维</option>
              <option value="corporate">企业培训总监 / HR</option>
              <option value="maker">独立创客 / 开发者</option>
              <option value="other">其他</option>
            </select>
          </div>
          <div>
            <label for="partnership-form-select" class="block text-xs font-bold font-mono tracking-wider text-brand-yellow mb-1.5">
              PARTNERSHIP FORM / 意向合作形态 *
            </label>
            <select id="partnership-form-select" name="partnership_form" required class="maker-input cursor-pointer">
              <option value="" disabled selected>请选择合作形态</option>
              <option value="A">形态 A · 标准课程授权</option>
              <option value="B">形态 B · 定制师资内训</option>
              <option value="C">形态 C · 空间联合共建</option>
              <option value="D">形态 D · 战略联合交付</option>
            </select>
          </div>
        </div>

        <div>
          <label for="form-contact" class="block text-xs font-bold font-mono tracking-wider text-brand-yellow mb-1.5">
            CONTACT INFO / 联系电话或微信号 *
          </label>
          <input
            type="text"
            id="form-contact"
            name="contact"
            autocomplete="tel"
            required
            placeholder="请输入您的手机号码或微信号码"
            class="maker-input"
          />
        </div>

        <div>
          <label for="form-message" class="block text-xs font-bold font-mono tracking-wider text-brand-yellow mb-1.5">
            MESSAGE / 需求描述或备注
          </label>
          <textarea
            id="form-message"
            name="message"
            rows="4"
            placeholder="例如：计划于今年秋季学期为电子专业引入 M0 与 M1，希望了解硬件套件采购和授权细节..."
            class="maker-input"
          ></textarea>
        </div>

        <div class="pt-2 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
          <button
            type="submit"
            class="focus-ring inline-flex items-center justify-center gap-2 px-8 py-4 bg-brand-red text-white font-bold rounded-lg hover:bg-brand-red-hover transition-all active:scale-[0.97] cursor-pointer"
          >
            提交表单需求
            <Icon name="lucide:send" class="w-4 h-4" />
          </button>

          <a
            href="mailto:jiayu.wang@seeed.cc?subject=学院课程合作咨询&body=您好！"
            id="direct-mail-link"
            class="focus-ring inline-flex items-center gap-1.5 text-xs text-white/60 hover:text-brand-yellow transition-colors font-mono"
          >
            <Icon name="lucide:mail" class="w-4 h-4" />
            或直接发送标准格式邮件
          </a>
        </div>
      </form>
    </div>

    <div class="space-y-6">
      <div class="panel-light p-6 text-brand-black text-center border-2 border-brand-black shadow-md flex flex-col items-center justify-center relative overflow-hidden bg-white">
        <div class="absolute top-0 right-0 bg-brand-yellow px-3 py-1 text-[10px] font-mono font-bold border-b-2 border-l-2 border-brand-black uppercase">
          FAST TRACK
        </div>
        <p class="text-sm font-black text-brand-black/50 mb-3 font-mono">WECHAT SERVICE / 微信直连</p>
        <span class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand-red text-white text-lg font-mono font-bold mb-4">
          <Icon name="lucide:message-square" class="w-6 h-6" />
        </span>
        <h4 class="text-lg font-black text-brand-black">微信直连学院顾问</h4>
        <p class="text-xs text-gray-500 mt-1 max-w-[240px]">
          如果您希望进行实时微信沟通，欢迎添加我们的学院合作顾问微信号：
        </p>
        <div class="mt-4 p-2 bg-brand-yellow-light border-2 border-dashed border-brand-black/20 rounded-lg w-full flex items-center justify-between gap-3">
          <span class="font-mono font-bold text-sm text-brand-black select-all pl-2">Seeed_Chaihuo</span>
          <button
            type="button"
            id="btn-copy-wechat"
            class="px-3 py-1.5 bg-brand-black text-white text-xs font-bold rounded hover:bg-brand-graphite active:scale-95 transition-all cursor-pointer"
          >
            复制号码
          </button>
        </div>
        <p class="text-[10px] text-gray-400 mt-4 leading-relaxed">
          工作时间：周一至周五 10:00–18:00 <br />
          添加时请备注“学院合作 + 您的单位”
        </p>
      </div>

      <div class="grid sm:grid-cols-2 md:grid-cols-1 gap-4">
        <div class="panel-light p-5 border-2 border-brand-black/5 hover:border-brand-black bg-white transition-colors duration-200">
          <div class="flex items-center gap-2 mb-2">
            <Icon name="lucide:map-pin" class="w-4 h-4 text-brand-red" />
            <span class="font-bold text-sm text-brand-black">深圳 HQ (总部)</span>
          </div>
          <p class="text-xs text-gray-600 leading-relaxed">
            深圳市南山区万科云城设计社区 B622
          </p>
          <a
            href="mailto:jiayu.wang@seeed.cc?subject=课程合作咨询(深圳)&body=您好！"
            class="focus-ring inline-block text-xs font-mono font-bold text-gray-500 mt-2 hover:text-brand-red transition-colors"
          >jiayu.wang@seeed.cc</a>
        </div>

        <div class="panel-light p-5 border-2 border-brand-black/5 hover:border-brand-black bg-white transition-colors duration-200">
          <div class="flex items-center gap-2 mb-2">
            <Icon name="lucide:map-pin" class="w-4 h-4 text-brand-red" />
            <span class="font-bold text-sm text-brand-black">成都分支机构</span>
          </div>
          <p class="text-xs text-gray-600 leading-relaxed">
            成都市青羊区狮马路 92 号
          </p>
          <a
            href="mailto:xia.huang@seeed.cc?subject=课程合作咨询(成都)&body=您好！"
            class="focus-ring inline-block text-xs font-mono font-bold text-gray-500 mt-2 hover:text-brand-red transition-colors"
          >xia.huang@seeed.cc</a>
        </div>
      </div>
    </div>
  </div>
</section>
