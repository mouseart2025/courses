---
import ScenarioCard from '../../ScenarioCard.astro';
import SectionHeader from '../../SectionHeader.astro';
import type { Scenario } from '../../../data/partnerships';

interface Props {
  scenarios: Scenario[];
}

const { scenarios } = Astro.props as Props;
---

<section class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-white">
  <div class="max-w-7xl mx-auto">
    <SectionHeader
      eyebrow="Step 1 · 选场景"
      title="你更接近哪一类？"
      subtitle="每个场景下方标注了适配的合作形态（A / B / C / D），点击即可跳转。"
    />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
      {scenarios.map((s) => <ScenarioCard scenario={s} />)}
    </div>
  </div>
</section>
