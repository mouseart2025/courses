---
import { Icon } from 'astro-icon/components';
import type { Module } from '../../../data/modules';

interface Props {
  module: Module;
  totalDays: number;
}

const { module } = Astro.props as Props;
const isM0 = module.id === 'm0';
const illoBg = isM0 ? 'bg-brand-yellow/15' : 'bg-brand-yellow-light';

// On-palette difficulty coding (no off-palette green): 入门 灰 · 进阶 黄 · 高级 红
const difficultyDot: Record<string, string> = {
  入门: 'bg-neutral-5',
  进阶: 'bg-brand-yellow',
  高级: 'bg-brand-red',
};
const diffDotClass = difficultyDot[module.difficulty] ?? 'bg-neutral-5';
---

<section class="bg-brand-yellow-light noise-overlay border-b border-neutral-3 py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8" data-reveal>
    <a
      href="/courses"
      class="focus-ring inline-flex items-center gap-1.5 text-sm font-semibold text-brand-black hover:text-brand-red transition-colors mb-8"
      aria-label="返回课程矩阵"
    >
      <Icon name="lucide:arrow-left" class="w-4 h-4" />
      返回课程矩阵
    </a>

    <div class="grid lg:grid-cols-[1.3fr_1fr] gap-12 lg:gap-16 items-center">
      <div>
        <div class="flex items-center gap-3.5 mb-6">
          <span class:list={[
            'module-tile module-tile--lg font-mono',
            isM0 ? 'module-tile--red' : 'module-tile--dark',
          ]}>
            {module.code}
          </span>
          <span class="text-sm font-bold tracking-widest uppercase text-brand-black/60 font-mono">
            {module.subtitle}
          </span>
        </div>

        <h1 class="text-[clamp(2.25rem,4vw+1rem,3.75rem)] font-black leading-tight text-brand-black tracking-tight">
          {module.title}
        </h1>
        <p class="mt-6 text-lg md:text-xl leading-relaxed text-gray-700 max-w-2xl">
          {module.oneLiner}
        </p>

        <div class="mt-6 border-l-4 border-brand-red bg-white/70 backdrop-blur-sm px-4 py-3 max-w-2xl rounded-r-lg">
          <p class="text-xs font-mono font-bold uppercase tracking-widest text-brand-red mb-1">这个模块解决什么</p>
          <p class="text-sm leading-relaxed text-brand-black">{module.realProblem}</p>
        </div>

        <div class="mt-8 flex flex-wrap gap-3 text-xs font-mono font-bold">
          <span class="inline-flex items-center gap-2 bg-background border border-neutral-3 px-3.5 py-2 rounded-lg shadow-xs text-brand-black">
            <span class:list={['w-2 h-2 rounded-full shrink-0', diffDotClass]} aria-hidden="true"></span>
            难度 {module.difficulty}
          </span>
          <span class="inline-flex items-center gap-1.5 bg-background border border-neutral-3 px-3.5 py-2 rounded-lg shadow-xs text-brand-black">
            <Icon name="lucide:clock" class="w-4 h-4 text-brand-red" />
            {module.duration}
          </span>
          <span class="inline-flex items-center gap-1.5 bg-background border border-neutral-3 px-3.5 py-2 rounded-lg shadow-xs text-brand-black">
            <Icon name="lucide:users" class="w-4 h-4 text-brand-red" />
            {module.audience.length} 类受众群体
          </span>
        </div>

        {module.prerequisite && (
          <p class="mt-4 inline-flex items-center gap-1.5 text-xs font-semibold text-brand-black/70">
            <Icon name="lucide:route" class="w-4 h-4 text-brand-red" />
            {module.prerequisite}
          </p>
        )}

        <div class="mt-6">
          <p class="text-xs font-mono font-bold uppercase tracking-widest text-brand-black/55 mb-2">典型应用场景</p>
          <div class="flex flex-wrap gap-2">
            {module.scenarios.map((s) => (
              <span class="inline-flex items-center rounded-full bg-white/70 border border-brand-black/15 px-3 py-1 text-xs font-semibold text-brand-black">
                {s}
              </span>
            ))}
          </div>
        </div>
      </div>

      <div>
        <div
          class:list={[
            'aspect-[4/3] w-full max-w-md mx-auto rounded-lg flex items-center justify-center overflow-hidden border border-neutral-3 relative shadow-sm-soft z-10',
            illoBg,
          ]}
        >
          <img
            src={module.illustration}
            alt={`${module.title} 插画`}
            width="1024"
            height="1024"
            class="w-full h-full object-cover relative z-10"
            loading="eager"
            fetchpriority="high"
            onerror="this.style.display='none'; this.nextElementSibling.classList.remove('hidden')"
          />
          <div class="absolute inset-0 hidden flex flex-col items-center justify-center text-center p-4 bg-brand-black/5 z-0">
            <Icon name="lucide:cpu" class="w-12 h-12 mb-2 text-brand-black opacity-30" />
            <span class="text-4xl font-mono font-black tracking-wider text-brand-black opacity-30">
              {module.code}
            </span>
            <span class="text-[10px] font-mono tracking-widest text-brand-black opacity-45 uppercase mt-1">
              WORKBENCH IMAGE
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
