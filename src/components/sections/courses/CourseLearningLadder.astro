---
import { Icon } from 'astro-icon/components';
import LevelBadge from '../../LevelBadge.astro';
import SectionHeader from '../../SectionHeader.astro';
import {
  levels,
  levelMeta,
  type LevelId,
  type Module,
} from '../../../data/modules';

interface Props {
  module: Module;
}

const { module } = Astro.props as Props;
---

<section class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-brand-yellow-light/30 border-t border-b border-brand-black/5">
  <div class="max-w-6xl mx-auto" data-reveal>
    <SectionHeader
      eyebrow="Learning Ladder"
      title="三阶递进：展示层 → 顾问层 → 设计层"
    />
    <div class="grid md:grid-cols-3 gap-6 mt-8">
      {
        levels.map((lvl: LevelId) => {
          const cell = module.cells[lvl];
          const cardBgClass = {
            L1: 'bg-brand-yellow-light border-brand-yellow-dark/20 text-brand-black',
            L2: 'bg-brand-yellow-mid border-brand-yellow-dark/30 text-brand-black',
            L3: 'bg-brand-red-light border-brand-red/20 text-brand-black',
          }[lvl];

          return (
            <div class:list={['border p-6 rounded-lg flex flex-col gap-5 shadow-xs', cardBgClass, cell.comingSoon && 'border-dashed opacity-65']}>
              <div class="flex items-start justify-between gap-2">
                <LevelBadge level={lvl} label={levelMeta[lvl].label} size="md" />
                {cell.comingSoon ? (
                  <span class="text-xs font-mono font-bold text-brand-black/55 border border-dashed border-brand-black/30 px-2.5 py-1 rounded">
                    即将推出
                  </span>
                ) : (
                  <span class="text-xs font-mono font-bold bg-white/80 text-brand-black/85 border border-brand-black/10 px-2.5 py-1 rounded">
                    {cell.durationDays} 天
                  </span>
                )}
              </div>

              <div>
                <h4 class="text-xl font-black text-brand-black leading-tight">
                  {cell.title}
                </h4>
                <p class="text-xs font-medium text-brand-black/60 mt-1">
                  {cell.subtitle}
                </p>
              </div>

              <ul class="space-y-2.5 text-sm text-brand-black/90">
                {cell.outcomes.map((o) => (
                  <li class="flex items-start gap-2">
                    <Icon
                      name="lucide:circle-check-big"
                      class="w-4 h-4 text-brand-red mt-0.5 shrink-0"
                    />
                    <span>{o}</span>
                  </li>
                ))}
              </ul>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
