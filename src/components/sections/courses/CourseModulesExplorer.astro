---
import { Icon } from 'astro-icon/components';
import ModuleCard from '../../ModuleCard.astro';
import ModuleOneLiner from '../../ModuleOneLiner.astro';
import type { Module } from '../../../data/modules';

interface Props {
  modules: Module[];
}

const { modules } = Astro.props as Props;
---

<section id="module-reference" class="scroll-mt-24 py-12 md:py-16 px-4 sm:px-6 lg:px-8 bg-background border-t border-brand-black/10">
  <div class="max-w-6xl mx-auto" data-reveal>
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-8">
      <div>
        <p class="text-xs font-mono font-bold uppercase tracking-widest text-brand-red mb-2">
          Course Modules
        </p>
        <h2 class="text-2xl md:text-3xl font-black text-brand-black">
          六个可引入课程模块
        </h2>
        <p class="mt-3 text-sm md:text-base text-gray-600 max-w-2xl">
          每个模块都包含真实硬件、课堂实验、能力目标和可带走材料。可以单独引入，也可以组合成系列课程。
        </p>
      </div>

      <div class="inline-flex bg-background border-2 border-brand-black p-1 rounded-xl shrink-0 self-start md:self-auto select-none shadow-sm z-10">
        <button
          id="btn-card-view"
          type="button"
          class="focus-ring px-4 py-2 text-xs font-bold rounded-lg transition-colors flex items-center gap-1.5 text-gray-500 hover:text-brand-black cursor-pointer"
          aria-controls="wrapper-card-view"
          aria-pressed="false"
          aria-label="切换至卡片视图"
        >
          <Icon name="lucide:layers" class="w-3.5 h-3.5" />
          详细卡片
        </button>
        <button
          id="btn-list-view"
          type="button"
          class="focus-ring px-4 py-2 text-xs font-bold rounded-lg transition-colors flex items-center gap-1.5 bg-brand-black text-white cursor-pointer"
          aria-controls="wrapper-list-view"
          aria-pressed="true"
          aria-label="切换至列表视图"
        >
          <Icon name="lucide:menu" class="w-3.5 h-3.5" />
          紧凑列表
        </button>
      </div>
    </div>

    <div id="wrapper-card-view" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 transition-all duration-300" hidden>
      {modules.map((m) => <ModuleCard module={m} />)}
    </div>

    <div id="wrapper-list-view" class="space-y-3 transition-all duration-300">
      {modules.map((m) => <ModuleOneLiner module={m} />)}
    </div>
  </div>
</section>
