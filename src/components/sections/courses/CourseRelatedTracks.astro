---
import { Icon } from 'astro-icon/components';
import SectionHeader from '../../SectionHeader.astro';
import type { Track } from '../../../data/tracks';

interface Props {
  relatedTracks: Track[];
}

const { relatedTracks } = Astro.props as Props;
---

{
  relatedTracks.length > 0 && (
    <section class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-brand-yellow-light/20 border-t border-brand-black/5">
      <div class="max-w-6xl mx-auto" data-reveal>
        <SectionHeader
          eyebrow="Course Combinations"
          title="包含此模块的课程组合"
        />
        <div class="grid md:grid-cols-2 gap-6 mt-8">
          {relatedTracks.map((t) => (
            <a
              href={`/paths#track-${t.id}`}
              class="group panel-light panel-interactive border border-neutral-3 hover:border-brand-black/30 p-5 flex items-center gap-4 focus-ring"
              aria-label={`查看包含本模块的课程组合：${t.name}`}
            >
              <Icon
                name="lucide:route"
                class="w-6 h-6 text-brand-red shrink-0 animate-pulse"
              />
              <div class="flex-1 min-w-0">
                <h4 class="font-black text-brand-black text-base">{t.name}</h4>
                <p class="text-xs font-mono text-gray-500 mt-0.5">
                  {t.tagline}
                </p>
              </div>
              <Icon name="lucide:arrow-right" class="w-4 h-4 text-gray-400 group-hover:text-brand-black transition-colors" />
            </a>
          ))}
        </div>
      </div>
    </section>
  )
}
