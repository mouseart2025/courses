---
import { Icon } from 'astro-icon/components';
import SectionHeader from '../../SectionHeader.astro';
import type { Module } from '../../../data/modules';

interface Props {
  module: Module;
}

const { module } = Astro.props as Props;
const toolchain = module.toolchain;
---

{
  toolchain && (
    <section class="py-14 md:py-20 px-4 sm:px-6 lg:px-8 border-t border-neutral-3">
      <div class="max-w-6xl mx-auto" data-reveal>
        <SectionHeader
          eyebrow="Toolchain / 双平台接力"
          title={`Codecraft 帮你“敢做”，aily-blockly 帮你“做完”`}
          subtitle="M0 不用 Arduino IDE 手写 C++，而是采用矽递自研的双平台接力工具链。前半程零安装、5 分钟见效；后半程把作品搬回自己的电脑，变成能带走、能继续演进的工程。"
        />

        <div class="border border-neutral-3 rounded-lg overflow-hidden bg-card shadow-sm-soft">
          <div class="grid md:grid-cols-2">
            {toolchain.stages.map((stage, i) => (
              <div
                class:list={[
                  'p-6 md:p-7',
                  // 柔黄是全站唯一允许的黄面（docs/DESIGN.md §1.1）——不用饱和黄铺底。
                  stage.highlight ? 'bg-brand-yellow-light' : 'bg-card',
                  i > 0 && 'border-t md:border-t-0 md:border-l border-neutral-3',
                ]}
              >
                <h3 class="text-xl font-bold text-brand-black tracking-tight">{stage.name}</h3>
                <p class="mt-1 text-xs font-mono text-neutral-7">{stage.meta}</p>
                <ol class="mt-5 flex flex-wrap items-center gap-2">
                  {stage.steps.map((step, j) => (
                    <>
                      {j > 0 && (
                        <Icon
                          name="lucide:arrow-right"
                          class="w-4 h-4 text-neutral-5 shrink-0"
                          aria-hidden="true"
                        />
                      )}
                      <li class="bg-background border border-neutral-3 rounded-md px-3 py-1.5 text-sm font-bold text-brand-black whitespace-nowrap">
                        {step}
                      </li>
                    </>
                  ))}
                </ol>
              </div>
            ))}
          </div>

          <div class="bg-brand-graphite text-white px-6 md:px-7 py-4 flex flex-wrap items-baseline gap-x-3 gap-y-1">
            <b class="text-sm font-bold text-brand-yellow shrink-0">{toolchain.hinge.title}</b>
            <span class="text-sm text-white/70 leading-relaxed">{toolchain.hinge.body}</span>
          </div>
        </div>

        {toolchain.note && (
          <p class="mt-5 text-sm text-neutral-7 max-w-3xl leading-relaxed">{toolchain.note}</p>
        )}
      </div>
    </section>
  )
}
