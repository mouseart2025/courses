---
import SectionHeader from '../../SectionHeader.astro';
import TrackFlow from '../../TrackFlow.astro';
---

<section id="learning-tracks" class="py-14 md:py-20 px-4 sm:px-6 lg:px-8 bg-background">
  <div class="max-w-7xl mx-auto" data-reveal>
    <SectionHeader
      eyebrow="Course Combinations"
      title="三大课程方向"
      subtitle="这些方向不是人群标签，而是常见引入方式：用 AI 造物（M0）、造 AI 的物（M2 · M4）、解决方案（M1 · M3 · M5）。"
    />
    <div class="panel-light p-2 sm:p-4 border border-neutral-3 rounded-lg">
      <TrackFlow />
    </div>
  </div>
</section>
