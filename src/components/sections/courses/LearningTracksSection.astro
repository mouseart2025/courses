---
import SectionHeader from '../../SectionHeader.astro';
import TrackFlow from '../../TrackFlow.astro';
---

<section id="learning-tracks" class="py-14 md:py-20 px-4 sm:px-6 lg:px-8 bg-white">
  <div class="max-w-7xl mx-auto">
    <SectionHeader
      eyebrow="Learning Tracks"
      title="四条推荐路径，对齐真实岗位"
      subtitle="Track 是我们为典型角色预组合的学习路径，M0 → 方向模块 → M5。你也可以按自己的节奏自由拼接。"
    />
    <div class="panel-light p-2 sm:p-4 border-2 border-brand-black/5 rounded-2xl">
      <TrackFlow />
    </div>
  </div>
</section>
