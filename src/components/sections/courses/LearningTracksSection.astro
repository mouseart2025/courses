---
import SectionHeader from '../../SectionHeader.astro';
import TrackFlow from '../../TrackFlow.astro';
---

<section id="learning-tracks" class="py-14 md:py-20 px-4 sm:px-6 lg:px-8 bg-white">
  <div class="max-w-7xl mx-auto">
    <SectionHeader
      eyebrow="Course Combinations"
      title="六种典型课程组合"
      subtitle="这些组合不是人群标签，而是常见引入方式：基础启蒙、空间设备、远距物联、边缘视觉、空间智能、项目交付。"
    />
    <div class="panel-light p-2 sm:p-4 border-2 border-brand-black/5 rounded-2xl">
      <TrackFlow />
    </div>
  </div>
</section>
