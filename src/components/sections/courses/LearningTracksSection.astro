---
import SectionHeader from '../../SectionHeader.astro';
import TrackFlow from '../../TrackFlow.astro';
---

<section id="learning-tracks" class="py-14 md:py-20 px-4 sm:px-6 lg:px-8 bg-white">
  <div class="max-w-7xl mx-auto">
    <SectionHeader
      eyebrow="Goal-Oriented Paths"
      title="按目标拼路径，五种典型走法"
      subtitle="不按身份划分——这五条路径覆盖了大多数学习者真正想要达成的目标。每一条都给出推荐模块顺序。"
    />
    <div class="panel-light p-2 sm:p-4 border-2 border-brand-black/5 rounded-2xl">
      <TrackFlow />
    </div>
  </div>
</section>
