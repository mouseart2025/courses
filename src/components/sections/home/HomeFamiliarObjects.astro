---
import { Icon } from 'astro-icon/components';
import SectionHeader from '../../SectionHeader.astro';
import type { FamiliarObject } from '../../../data/site';

interface Props {
  objects: FamiliarObject[];
}

const { objects } = Astro.props as Props;
---

<section class="py-20 px-4 sm:px-6 lg:px-8 bg-white">
  <div class="max-w-7xl mx-auto">
    <SectionHeader
      eyebrow="Course Materials"
      title="课程从真实硬件和现场材料开始"
      subtitle="LED、传感器、网关、摄像头、空间设备、交付文档，这些不是概念入口，而是课堂实验、项目训练和合作交付里的真实材料。"
    />
    <ul class="mt-10 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-px bg-neutral-3 border border-neutral-3 rounded-lg overflow-hidden">
      {objects.map((o) => (
        <li class="bg-white">
          <a
            href={o.href}
            class="focus-ring group flex h-full flex-col gap-3 p-5 md:p-6 transition-colors hover:bg-neutral-1"
          >
            <Icon name={o.icon} class="w-6 h-6 text-brand-red" />
            <div>
              <p class="text-sm font-semibold text-brand-black leading-tight">{o.label}</p>
              <p class="mt-1 text-xs text-neutral-7 leading-relaxed">{o.hint}</p>
            </div>
            <span class="mt-auto inline-flex items-center gap-1 text-xs font-mono font-medium tracking-wider uppercase text-neutral-6">
              {o.moduleHint}
              <Icon name="lucide:arrow-right" class="w-3 h-3 text-neutral-5 transition-colors group-hover:text-brand-red" />
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
