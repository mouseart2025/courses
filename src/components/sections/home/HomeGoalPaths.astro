---
import { Icon } from 'astro-icon/components';
import SectionHeader from '../../SectionHeader.astro';
import type { Track } from '../../../data/tracks';
import { modules } from '../../../data/modules';

interface Props {
  tracks: Track[];
}

const { tracks } = Astro.props as Props;
const codeOf = (id: string) => modules.find((m) => m.id === id)?.code ?? id;
---

<section class="py-20 px-4 sm:px-6 lg:px-8 bg-background">
  <div class="max-w-6xl mx-auto" data-reveal>
    <SectionHeader
      eyebrow="Course Combinations"
      title="三大课程方向"
      subtitle="用 AI 造物、造 AI 的物、解决方案——三条主线对应不同目标与模块组合；每个方向都能继续细分到 L1 / L2 / L3。"
    />

    <ul class="mt-10 grid gap-5 md:grid-cols-3">
      {tracks.map((t) => (
        <li>
          <a
            href={`/paths#track-${t.id}`}
            class="focus-ring group card-hairline flex h-full flex-col p-6 transition-colors hover:border-brand-black/30"
          >
            <p class="text-xs font-mono font-semibold uppercase tracking-widest text-brand-red mb-2">
              {t.tagline}
            </p>
            <h3 class="text-lg md:text-xl font-bold text-brand-black leading-tight">
              {t.name}
            </h3>
            <p class="mt-1 text-sm text-neutral-7">{t.goal}</p>
            <p class="mt-3 text-sm leading-relaxed text-neutral-8">{t.description}</p>

            <div class="mt-5 flex flex-wrap items-center gap-2">
              {t.moduleIds.map((id) => (
                <span class="module-tile module-tile--dark font-mono text-xs px-2 py-1">
                  {codeOf(id)}
                </span>
              ))}
            </div>

            <span class="mt-auto pt-5 inline-flex items-center gap-1 text-sm font-semibold text-brand-black group-hover:text-brand-red transition-colors">
              查看方向
              <Icon name="lucide:arrow-right" class="w-4 h-4 transition-transform group-hover:translate-x-0.5" />
            </span>
          </a>
        </li>
      ))}
    </ul>

    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href="/paths"
        class="focus-ring inline-flex items-center justify-center gap-2 rounded-md bg-brand-black px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-black"
      >
        查看选课指南
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
      <a
        href="/courses"
        class="focus-ring inline-flex items-center justify-center gap-2 rounded-md border border-neutral-3 px-5 py-2.5 text-sm font-semibold text-brand-black transition-colors hover:border-brand-black/30 bg-background"
      >
        查看完整课程体系
      </a>
    </div>
  </div>
</section>
