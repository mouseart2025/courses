---
import { Icon } from 'astro-icon/components';
import ModuleCard from '../../ModuleCard.astro';
import SectionHeader from '../../SectionHeader.astro';
import type { Module } from '../../../data/modules';

interface Props {
  modules: Module[];
}

const { modules } = Astro.props as Props;
---

<section class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-brand-yellow-light noise-overlay border-t border-b border-brand-black/5">
  <div class="max-w-7xl mx-auto">
    <SectionHeader
      eyebrow="Course Matrix"
      title="六个模块，覆盖 AIoT 全栈交付"
      subtitle="M0 是所有人的起点；M1–M5 按方向各自独立，又能组合成完整路径。"
    />
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
      {modules.map((m) => <ModuleCard module={m} variant="compact" />)}
    </div>
    <div class="mt-12 text-center">
      <a
        href="/courses"
        class="focus-ring inline-flex items-center gap-2 text-brand-black font-bold hover:text-brand-red transition-colors"
      >
        查看 M0–M5 × L1/L2/L3 完整矩阵
        <Icon name="lucide:arrow-right" class="w-4 h-4 animate-pulse" />
      </a>
    </div>
  </div>
</section>
