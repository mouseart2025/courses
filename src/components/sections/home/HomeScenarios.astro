---
import { Icon } from 'astro-icon/components';
import ScenarioCard from '../../ScenarioCard.astro';
import SectionHeader from '../../SectionHeader.astro';
import type { Scenario } from '../../../data/partnerships';

interface Props {
  scenarios: Scenario[];
}

const { scenarios } = Astro.props as Props;
---

<section class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-white">
  <div class="max-w-7xl mx-auto">
    <SectionHeader
      eyebrow="Partnership Scenarios"
      title="三类典型合作场景"
      subtitle="高校、集成商、企业——每一类都有对应的合作形态与交付标准。"
    />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
      {scenarios.map((s) => <ScenarioCard scenario={s} compact />)}
    </div>
    <div class="mt-12 text-center">
      <a
        href="/contact"
        class="focus-ring inline-flex items-center justify-center gap-2 bg-brand-yellow text-brand-black border-2 border-brand-black font-bold px-6 py-3.5 rounded-xl hover:bg-brand-yellow-hover transition-colors shadow-sm"
      >
        查看完整合作方案
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </div>
  </div>
</section>
