---
import type { HomeValueStatement } from '../../../data/site';

interface Props {
  statement: HomeValueStatement;
}

const { statement } = Astro.props as Props;
---

<section class="py-20 md:py-28 px-4 sm:px-6 lg:px-8 bg-white">
  <div class="max-w-3xl mx-auto text-center">
    <p class="text-sm font-semibold uppercase tracking-wider text-brand-red mb-4">
      {statement.eyebrow}
    </p>
    <p class="text-2xl md:text-4xl font-black text-brand-black leading-snug">
      {statement.leadPrefix}<br />
      而是培养<span class="highlight">{statement.leadHighlight}</span>。
    </p>
    <p class="mt-6 text-base md:text-lg text-gray-600 leading-relaxed max-w-2xl mx-auto">
      {statement.description}
    </p>
  </div>
</section>
