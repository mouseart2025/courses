---
import type { CollectionEntry } from 'astro:content';

interface Props {
  partners: CollectionEntry<'partners'>[];
}

const { partners } = Astro.props as Props;
---

<section class="py-20 px-4 sm:px-6 lg:px-8 bg-background border-t border-neutral-3">
  <div class="max-w-6xl mx-auto" data-reveal>
    <p class="text-center text-xs font-mono font-semibold uppercase tracking-widest text-neutral-6 mb-10">
      生态合作伙伴
    </p>
    <div class="grid grid-cols-3 md:grid-cols-6 gap-8 items-center">
      {
        partners.map((entry) => (
          <div class="flex items-center justify-center h-12">
            {entry.data.logo ? (
              <img
                src={entry.data.logo}
                alt={entry.data.name}
                class="h-8 w-auto grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
                loading="lazy"
              />
            ) : (
              <span class="text-xs font-mono text-neutral-5 font-semibold">
                {entry.data.name}
              </span>
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>
