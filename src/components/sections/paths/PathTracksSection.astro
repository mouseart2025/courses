---
import { Icon } from 'astro-icon/components';
import SectionHeader from '../../SectionHeader.astro';
import type { Track } from '../../../data/tracks';
import { getModule } from '../../../data/modules';

interface Props {
  tracks: Track[];
}

const { tracks } = Astro.props as Props;
---

<section id="tracks" class="py-16 md:py-24 px-4 sm:px-6 lg:px-8 bg-background">
  <div class="max-w-7xl mx-auto" data-reveal>
    <SectionHeader
      eyebrow="Course Packages"
      title="三大课程方向"
      subtitle="三个并列方向，按课程目标给出建议组合。每个方向都对应模块、硬件、实验和交付材料，最终可以按你的场景调整深度和课时。"
    />

    <ul class="mt-10 grid gap-6 lg:grid-cols-3">
      {
        tracks.map((track) => (
          <li>
            <article
              id={`track-${track.id}`}
              class="card-hairline scroll-mt-24 flex h-full flex-col p-6"
            >
              <p class="text-xs font-mono font-semibold uppercase tracking-widest text-brand-red">
                {track.tagline}
              </p>
              <h2 class="mt-2 text-xl md:text-2xl font-bold text-brand-black leading-tight">
                {track.name}
              </h2>
              <p class="mt-2 text-sm font-semibold text-neutral-7">{track.goal}</p>
              <p class="mt-3 text-sm leading-relaxed text-neutral-8">
                {track.description}
              </p>

              <ul class="mt-5 space-y-2.5 border-t border-neutral-3 pt-5">
                {track.moduleIds.map((id) => {
                  const module = getModule(id);
                  if (!module) return null;
                  return (
                    <li>
                      <a
                        href={`/courses/${module.slug}`}
                        class="focus-ring group flex items-center gap-3"
                        aria-label={`查看 ${module.code} ${module.title}`}
                      >
                        <span
                          class:list={[
                            'module-tile module-tile--sm shrink-0',
                            module.accent === 'red'
                              ? 'module-tile--red'
                              : 'module-tile--dark',
                          ]}
                        >
                          {module.code}
                        </span>
                        <span class="text-sm font-semibold text-brand-black leading-tight group-hover:text-brand-red transition-colors">
                          {module.title}
                        </span>
                      </a>
                    </li>
                  );
                })}
              </ul>

              <div class="mt-auto pt-6 flex flex-col gap-2">
                <a
                  href={`/courses#track-${track.id}`}
                  class="focus-ring inline-flex items-center justify-center gap-2 rounded-md bg-brand-black px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-black"
                >
                  在课程体系中定位
                  <Icon name="lucide:arrow-right" class="w-4 h-4" />
                </a>
                <a
                  href="/contact"
                  class="focus-ring inline-flex items-center justify-center gap-2 rounded-md border border-neutral-3 bg-background px-4 py-2.5 text-sm font-semibold text-brand-black transition-colors hover:border-brand-black/30"
                >
                  带着这组课程咨询
                </a>
              </div>
            </article>
          </li>
        ))
      }
    </ul>
  </div>
</section>
