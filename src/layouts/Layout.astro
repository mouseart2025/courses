---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "柴火创客学院 · 从第一次点亮 LED，到独立交付智能系统",
  ogImage = "/logo-horizontal.png",
} = Astro.props as Props;

const currentPath = Astro.url.pathname;
const siteName = "柴火创客学院";
const fullTitle = `${title} | ${siteName}`;

// Absolute URLs for Open Graph / Twitter Card
const canonicalUrl = new URL(currentPath, Astro.site ?? Astro.url).toString();
const ogImageUrl = new URL(ogImage, Astro.site ?? Astro.url).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Favicon uses the extracted brand mark; apple touch keeps the PNG fallback. -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/logo-vertical.png" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook / WeChat / WeWork -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content="柴火创客 CHAIHUO MAKERS" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="柴火创客 CHAIHUO MAKERS" />

    <!-- Theme color (mobile browser chrome) -->
    <meta name="theme-color" content="#f3d230" />

    <!-- Fonts (v2.1 — 三轨字体) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;600;700;900&family=JetBrains+Mono:wght@500;700&family=Caveat:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />
    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-white text-gray-900 antialiased">
    <a href="#main-content" class="skip-link focus-ring">跳到主要内容</a>
    <Navbar currentPath={currentPath} />

    <main id="main-content" class="flex-1" tabindex="-1">
      <slot />
    </main>

    <Footer />

    <script>
      import "preline/preline";

      declare global {
        interface Window {
          HSStaticMethods?: {
            autoInit(): void;
          };
        }
      }

      document.addEventListener("astro:page-load", () => {
        if (window.HSStaticMethods) {
          window.HSStaticMethods.autoInit();
        }
      });
    </script>
  </body>
</html>
