---
import HeroBanner from '../components/HeroBanner.astro';
import Layout from '../layouts/Layout.astro';
import AboutEcosystemSection from '../components/sections/about/AboutEcosystemSection.astro';
import AboutStatsSection from '../components/sections/about/AboutStatsSection.astro';
import AboutValuesSection from '../components/sections/about/AboutValuesSection.astro';
import FinalCtaSection from '../components/sections/FinalCtaSection.astro';
import {
  aboutEcosystem,
  aboutFinalCta,
  aboutStats,
  aboutValues,
} from '../data/site';
---

<Layout title="关于学院">
  <HeroBanner
    eyebrow="关于学院"
    title="从硬件供应链、创客空间到课程体系"
    description="柴火创客 OPC 学院是柴火创客生态的技术赋能平台。课程来自真实硬件、真实场景和长期项目实践。"
    ctas={[
      { label: '查看课程体系', href: '/courses', variant: 'primary' },
      { label: '查看选课指南', href: '/paths', variant: 'secondary' },
    ]}
  />

  <AboutEcosystemSection ecosystem={aboutEcosystem} />
  <AboutValuesSection values={aboutValues} />
  <AboutStatsSection stats={aboutStats} />
  <FinalCtaSection cta={aboutFinalCta} bordered />
</Layout>
