---
import Layout from "../layouts/Layout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ScenarioCard from "../components/ScenarioCard.astro";
import PartnershipCard from "../components/PartnershipCard.astro";
import { scenarios, partnershipForms } from "../data/partnerships";
import { Icon } from "astro-icon/components";

const faqs = [
  {
    question: "合作从提交表单到启动一般需要多久？",
    answer: "首次对齐通常 3 个工作日内安排会议；定制内训从需求确认到开课一般 2–4 周；战略联合交付视合作深度而定。",
  },
  {
    question: "课程是否可以只引入某个模块或层级？",
    answer: "可以。M0–M5 每个模块都是独立设计的，L1/L2/L3 也可以单独引入。我们会根据你的目标推荐最小有效组合。",
  },
  {
    question: "合作是否包含硬件？",
    answer: "标准授权与内训默认包含推荐硬件清单，可以采购 Seeed 套件、使用自有硬件或混合方案。具体按项目报价。",
  },
  {
    question: "是否接受海外合作？",
    answer: "接受。柴火创客学院依托 Seeed 全球供应链，支持英文交付和海外师资外派。",
  },
];
---

<Layout title="合作咨询">
  <!-- Hero -->
  <section class="bg-gray-50 border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <p
        class="text-sm font-medium text-brand-red tracking-wide mb-4"
      >
        合作咨询
      </p>
      <h1
        class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight text-gray-900 max-w-3xl"
      >
        3 类合作场景 · 4 种合作形态<br />总有一款对齐你的目标
      </h1>
      <p class="mt-4 text-lg text-gray-600 max-w-2xl leading-relaxed">
        告诉我们你是谁、想做什么，我们给出清晰的合作路径与交付标准。
      </p>
    </div>
  </section>

  <!-- Scenarios -->
  <section class="py-14 md:py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <SectionHeader
        eyebrow="Step 1 · 选场景"
        title="你更接近哪一类？"
        subtitle="每个场景下方标注了适配的合作形态（A / B / C / D），点击即可跳转。"
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {scenarios.map((s) => <ScenarioCard scenario={s} />)}
      </div>
    </div>
  </section>

  <!-- Partnership forms -->
  <section class="py-14 md:py-20 px-4 sm:px-6 lg:px-8 bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <SectionHeader
        eyebrow="Step 2 · 选形态"
        title="四种合作形态，对应不同深度"
        subtitle="从标准授权到战略联合，合作深度决定交付的颗粒度与知识产权归属。"
      />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {partnershipForms.map((f) => <PartnershipCard form={f} />)}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-14 md:py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      <SectionHeader eyebrow="FAQ" title="常见问题" align="center" />
      <div class="space-y-3">
        {faqs.map((faq, index) => (
          <div
            class="hs-accordion card-hairline bg-white"
            id={`faq-accordion-${index}`}
          >
            <button
              id={`faq-accordion-trigger-${index}`}
              class="hs-accordion-toggle hs-accordion-active:text-brand-red py-5 px-6 inline-flex items-center justify-between gap-x-3 w-full font-semibold text-left text-brand-black transition hover:text-brand-red cursor-pointer"
              aria-expanded="false"
              aria-controls={`faq-accordion-content-${index}`}
            >
              {faq.question}
              <Icon
                name="lucide:chevron-down"
                class="hs-accordion-active:hidden block w-4 h-4 text-gray-400"
              />
              <Icon
                name="lucide:chevron-up"
                class="hs-accordion-active:block hidden w-4 h-4 text-brand-red"
              />
            </button>
            <div
              id={`faq-accordion-content-${index}`}
              class="hs-accordion-content hidden w-full overflow-hidden transition-[height] duration-300"
              role="region"
              aria-labelledby={`faq-accordion-trigger-${index}`}
            >
              <p class="pb-5 px-6 text-gray-600 leading-relaxed">
                {faq.answer}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact block -->
  <section
    id="partnership-form"
    class="py-14 md:py-20 px-4 sm:px-6 lg:px-8 bg-gray-50 border-t border-gray-200"
  >
    <div class="max-w-6xl mx-auto grid md:grid-cols-[1.3fr_1fr] gap-10 items-start">
      <div>
        <h2
          class="text-2xl sm:text-3xl font-bold leading-tight text-gray-900"
        >
          提交需求，开启合作
        </h2>
        <p class="mt-4 text-gray-600 leading-relaxed">
          告诉我们你的目标、团队规模与预期时间线，我们 3 个工作日内反馈合作建议书。
        </p>

        <div class="mt-8 grid sm:grid-cols-2 gap-4">
          <div class="card-hairline bg-white p-5">
            <div class="flex items-center gap-2 mb-2">
              <Icon name="lucide:map-pin" class="w-4 h-4 text-brand-red" />
              <span class="font-semibold text-sm text-brand-black">深圳 HQ</span>
            </div>
            <p class="text-sm text-gray-600 leading-relaxed">
              深圳市南山区万科云城设计社区 B622
            </p>
            <a
              href="mailto:jiayu.wang@seeed.cc"
              class="focus-ring inline-block text-sm text-gray-500 mt-1 hover:text-brand-red transition-colors"
            >jiayu.wang@seeed.cc</a>
          </div>
          <div class="card-hairline bg-white p-5">
            <div class="flex items-center gap-2 mb-2">
              <Icon name="lucide:map-pin" class="w-4 h-4 text-brand-red" />
              <span class="font-semibold text-sm text-brand-black">成都</span>
            </div>
            <p class="text-sm text-gray-600 leading-relaxed">
              成都市青羊区狮马路 92 号
            </p>
            <a
              href="mailto:xia.huang@seeed.cc"
              class="focus-ring inline-block text-sm text-gray-500 mt-1 hover:text-brand-red transition-colors"
            >xia.huang@seeed.cc</a>
          </div>
        </div>

        <p class="mt-8 text-sm text-gray-600 leading-relaxed">
          扫描右侧二维码，填写合作需求表单 —— 我们会在 3 个工作日内反馈合作建议书。
        </p>
      </div>

      <div class="card-hairline bg-white p-6 text-brand-black text-center">
        <p class="text-sm font-semibold text-gray-500 mb-3">扫码填写合作需求表单</p>
        <div
          class="aspect-square w-full max-w-[220px] mx-auto bg-gray-100 flex items-center justify-center rounded-lg overflow-hidden"
        >
          <img
            src="/qr-partnership.png"
            alt="合作咨询二维码"
            class="w-full h-full object-contain"
            loading="lazy"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
          />
          <div
            class="hidden w-full h-full items-center justify-center text-gray-400 text-sm"
          >
            QR Code
          </div>
        </div>
        <p class="text-xs text-gray-500 mt-3">周一至周五 10:00–18:00</p>
      </div>
    </div>
  </section>
</Layout>
