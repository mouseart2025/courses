---
import Layout from '../../layouts/Layout.astro';
import CourseAudienceSection from '../../components/sections/courses/CourseAudienceSection.astro';
import CourseDetailHero from '../../components/sections/courses/CourseDetailHero.astro';
import CourseDetailPanels from '../../components/sections/courses/CourseDetailPanels.astro';
import CourseDeliverables from '../../components/sections/courses/CourseDeliverables.astro';
import CourseLearningLadder from '../../components/sections/courses/CourseLearningLadder.astro';
import CourseRelatedTracks from '../../components/sections/courses/CourseRelatedTracks.astro';
import FinalCtaSection from '../../components/sections/FinalCtaSection.astro';
import { modules, type Module } from '../../data/modules';
import { getTracksForModule } from '../../data/tracks';
import type { FinalCta } from '../../data/site';

export const prerender = true;

export async function getStaticPaths() {
  return modules.map((m) => ({
    params: { slug: m.slug },
    props: { module: m },
  }));
}

interface Props {
  module: Module;
}

const { module } = Astro.props as Props;
const relatedTracks = getTracksForModule(module.id);
const totalDays = Object.values(module.cells).reduce(
  (sum, cell) => sum + cell.durationDays,
  0,
);

const courseDetailCta: FinalCta = {
  eyebrow: 'APPLY FOR COOPERATION',
  title: `把 ${module.code} 放进你的课程、团队或项目现场`,
  description:
    '如果这个方向正好对上你的目标，可以继续讨论课程授权、联合共建、定制内训或长期联合交付。',
  primary: { label: '立即申请合作', href: '/contact' },
  secondary: { label: '浏览其他模块', href: '/courses' },
};

const siteOrigin = (Astro.site?.toString() ?? 'https://opc.chaihuo.org/').replace(/\/$/, '');
const courseUrl = `${siteOrigin}/courses/${module.slug}`;

const courseJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: `${module.code} · ${module.title}`,
  description: `${module.oneLiner}。${module.realProblem}`,
  url: courseUrl,
  inLanguage: 'zh-CN',
  courseCode: module.code,
  about: module.subtitle,
  teaches: module.capabilities,
  timeRequired: `P${totalDays}D`,
  educationalLevel: ['Beginner', 'Intermediate', 'Advanced'],
  provider: {
    '@type': 'Organization',
    name: '柴火创客学院',
    url: siteOrigin,
    sameAs: ['https://www.chaihuo.org', 'https://www.seeedstudio.com'],
  },
  audience: module.audience.map((role) => ({
    '@type': 'EducationalAudience',
    educationalRole: role,
  })),
  hasPart: Object.entries(module.cells).map(([levelId, cell]) => ({
    '@type': 'Course',
    name: `${module.code} · ${levelId} · ${cell.title}`,
    description: cell.subtitle,
    timeRequired: `P${cell.durationDays}D`,
    teaches: cell.outcomes,
    inLanguage: 'zh-CN',
  })),
};

// Escape `<` so a stray `</script>` in any future data field cannot break out of the script tag.
const courseJsonLdSafe = JSON.stringify(courseJsonLd).replace(/</g, '\\u003c');
---

<Layout title={`${module.code} · ${module.title}`}>
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={courseJsonLdSafe}
  />
  <CourseDetailHero module={module} totalDays={totalDays} />
  <CourseDetailPanels module={module} />
  <CourseLearningLadder module={module} />
  <CourseDeliverables module={module} />
  <CourseAudienceSection module={module} />
  <CourseRelatedTracks relatedTracks={relatedTracks} />
  <FinalCtaSection cta={courseDetailCta} bordered />
</Layout>
