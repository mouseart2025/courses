---
import { getCollection } from 'astro:content';
import HeroBanner from '../components/HeroBanner.astro';
import Layout from '../layouts/Layout.astro';
import FinalCtaSection from '../components/sections/FinalCtaSection.astro';
import HomeModuleGrid from '../components/sections/home/HomeModuleGrid.astro';
import HomeScenarios from '../components/sections/home/HomeScenarios.astro';
import HomeValueStatement from '../components/sections/home/HomeValueStatement.astro';
import PartnerLogoGrid from '../components/sections/home/PartnerLogoGrid.astro';
import { modules } from '../data/modules';
import { scenarios } from '../data/partnerships';
import { homeFinalCta, homeValueStatement } from '../data/site';

const partners = await getCollection('partners');
partners.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
---

<Layout title="首页">
  <HeroBanner
    eyebrow="2026 课程体系 · M0 + M1–M5"
    title="从第一次点亮 LED，到独立交付智能系统"
    subtitle="柴火创客学院 · Chaihuo Maker Academy"
    description="背靠 Seeed Studio 与柴火创客空间，我们用真实硬件、真实场景、真实项目，培养人掌握新技术整合能力。"
    ctas={[
      { label: '探索课程矩阵', href: '/courses', variant: 'primary' },
      { label: '申请合作', href: '/contact', variant: 'secondary' },
    ]}
  >
    <Fragment slot="title">
      从第一次点亮 LED，到<span class="highlight">独立交付智能系统</span>
    </Fragment>
  </HeroBanner>

  <HomeValueStatement statement={homeValueStatement} />
  <HomeModuleGrid modules={modules} />
  <HomeScenarios scenarios={scenarios} />
  <PartnerLogoGrid partners={partners} />
  <FinalCtaSection cta={homeFinalCta} bordered headingSize="xl" />
</Layout>
